---
import { t } from '../i18n/index';
import type { Lang } from '../i18n/index';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = t(lang);
const homeHref = lang === 'it' ? '/' : '/en/';
---

<footer class="bg-black text-neutral-400 py-12 border-t border-[#1a1a1a]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-10">

      <!-- Brand -->
      <div>
        <a href={homeHref} class="font-display font-bold text-xl text-amber-400 hover:text-amber-300 transition-colors">
          SCJAVURU of HOME
        </a>
        <p class="text-neutral-600 mt-2 text-sm leading-relaxed">{tr.footer.tagline}</p>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="text-xs font-semibold tracking-widest uppercase text-neutral-700 mb-4">Menu</h3>
        <nav class="flex flex-col gap-2">
          {[
            { href: '#galleria', label: tr.nav.gallery },
            { href: '#prenota', label: tr.nav.booking },
            { href: '#dove-siamo', label: tr.nav.location },
            { href: '#prezzi', label: tr.nav.prices },
          ].map(({ href, label }) => (
            <a href={href} class="text-sm text-neutral-500 hover:text-amber-400 transition-colors">{label}</a>
          ))}
        </nav>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-xs font-semibold tracking-widest uppercase text-neutral-700 mb-4">{tr.footer.contact}</h3>
        <a
          href="mailto:scjavuruhosteria@libero.it"
          class="flex items-center gap-2 text-sm text-neutral-500 hover:text-amber-400 transition-colors"
        >
          <svg class="w-4 h-4 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          scjavuruhosteria@libero.it
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-[#1a1a1a] pt-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-neutral-700">
      <p>{tr.footer.rights}</p>
      <div class="flex gap-4">
        <a href="/" class={['hover:text-amber-400 transition-colors', lang === 'it' ? 'text-amber-400' : ''].join(' ')}>IT</a>
        <span>|</span>
        <a href="/en/" class={['hover:text-amber-400 transition-colors', lang === 'en' ? 'text-amber-400' : ''].join(' ')}>EN</a>
      </div>
    </div>
  </div>
</footer>
