---
import { t } from '../i18n/index';
import type { Lang } from '../i18n/index';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = t(lang);

const googleMapsUrl = 'https://maps.app.goo.gl/rb424gV757d848Yn7';

// Via Roma, 443 — Palermo
const LAT = 38.1227062;
const LON = 13.3604854;

// Calcolo automatico del bounding box per OpenStreetMap (non modificare)
const delta = 0.025;
const bbox = `${LON - delta}%2C${LAT - delta}%2C${LON + delta}%2C${LAT + delta}`;
const osmUrl = `https://www.openstreetmap.org/export/embed.html?bbox=${bbox}&layer=mapnik&marker=${LAT}%2C${LON}`;
---

<section id="dove-siamo" class="py-20 lg:py-28 bg-[#111111]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-14">
      <h2 class="font-display text-4xl lg:text-5xl font-bold text-white mb-4">
        {tr.location.title}
      </h2>
      <p class="text-lg text-neutral-400 max-w-xl mx-auto">
        {tr.location.subtitle}
      </p>
      <div class="mt-5 w-14 h-0.5 bg-amber-400 mx-auto"></div>
    </div>

    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-start">

      <div class="flex flex-col justify-center">
        <p class="text-neutral-300 text-lg leading-relaxed mb-8">
          {tr.location.description}
        </p>

        <div class="flex items-center gap-3 bg-[#1a1a1a] rounded-xl px-5 py-4 border border-amber-400/20 mb-6">
          <div class="w-10 h-10 rounded-full bg-amber-400/10 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
            </svg>
          </div>
          <span class="text-neutral-200 font-medium">{tr.location.address}</span>
        </div>

        <ul class="space-y-3">
          {[
            lang === 'it' ? '🎭  Teatro Massimo a pochi passi' : '🎭  Teatro Massimo steps away',
            lang === 'it' ? '🛍️  Via Maqueda a 1 km' : '🛍️  Via Maqueda 1 km away',
            lang === 'it' ? '⛪  Cattedrale di Palermo a 1 km' : '⛪  Palermo Cathedral 1 km away',
            lang === 'it' ? '✈️  Aeroporto Falcone-Borsellino a 28 km' : '✈️  Falcone-Borsellino airport 28 km away',
          ].map((item) => (
            <li class="flex items-center gap-2 text-neutral-400">
              <span>{item}</span>
            </li>
          ))}
        </ul>

        <a href={googleMapsUrl} target="_blank" rel="noopener noreferrer"
          class="mt-8 inline-flex items-center gap-2 text-amber-400 hover:text-amber-300 font-semibold transition-colors">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
          {tr.location.openMap}
        </a>
      </div>

      <div class="rounded-2xl overflow-hidden shadow-xl border border-[#2a2a2a]">
        <iframe src={osmUrl} width="100%" height="450"
          style="border:0; display:block;" loading="lazy"
          title="Mappa struttura" aria-label="Mappa">
        </iframe>
      </div>
    </div>
  </div>
</section>
