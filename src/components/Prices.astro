---
import { t } from '../i18n/index';
import type { Lang } from '../i18n/index';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = t(lang);

// ✏️  Aggiorna con il link Airbnb principale (o alla tua pagina host) quando disponibile
const AIRBNB_URL = 'https://www.airbnb.it/rooms/1629916151179013176';
---

<section id="prezzi" class="py-20 lg:py-28 bg-white">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-14">
      <h2 class="font-display text-4xl lg:text-5xl font-bold text-slate-800 mb-4">
        {tr.prices.title}
      </h2>
      <p class="text-lg text-slate-500 max-w-2xl mx-auto">
        {tr.prices.subtitle}
      </p>
      <div class="mt-5 w-14 h-0.5 bg-amber-400 mx-auto"></div>
    </div>

    <!-- Two cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">

      <!-- Airbnb card -->
      <div class="rounded-2xl border border-slate-100 bg-white shadow-md p-8 flex flex-col">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-12 h-12 rounded-xl bg-rose-50 flex items-center justify-center flex-shrink-0">
            <!-- Airbnb logo icon -->
            <svg class="w-6 h-6 text-rose-500" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.373 0 0 5.372 0 12c0 6.627 5.373 12 12 12s12-5.373 12-12c0-6.628-5.373-12-12-12zm.36 17.448c-.23.168-.49.252-.76.252s-.53-.084-.76-.252c-.84-.613-5.04-3.864-5.04-7.368 0-3.204 2.556-5.076 5.8-5.076 3.244 0 5.8 1.872 5.8 5.076 0 3.504-4.2 6.755-5.04 7.368z"/>
            </svg>
          </div>
          <div>
            <span class="text-xs font-semibold tracking-widest uppercase text-slate-400">{tr.prices.airbnbCard.label}</span>
            <div class="font-display font-bold text-lg text-slate-800">Airbnb</div>
          </div>
        </div>

        <p class="text-slate-500 text-sm leading-relaxed flex-1 mb-8">
          {tr.prices.airbnbCard.note}
        </p>

        <a
          href={AIRBNB_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center gap-2 bg-rose-500 hover:bg-rose-600 text-white font-semibold text-sm px-6 py-3 rounded-full transition-all duration-200 hover:scale-105 shadow-md shadow-rose-500/20"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
          {tr.prices.airbnbCard.cta}
        </a>
      </div>

      <!-- Discount card -->
      <div class="rounded-2xl bg-amber-400 p-8 flex flex-col relative overflow-hidden">
        <!-- Background decoration -->
        <div class="absolute -top-6 -right-6 w-32 h-32 bg-amber-300/40 rounded-full"></div>
        <div class="absolute -bottom-8 -left-4 w-24 h-24 bg-amber-500/30 rounded-full"></div>

        <div class="relative z-10 flex flex-col h-full">
          <span class="inline-flex self-start items-center gap-1.5 bg-slate-900/10 text-slate-900 text-xs font-bold tracking-widest uppercase px-3 py-1 rounded-full mb-6">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
            {tr.prices.discountCard.badge}
          </span>

          <h3 class="font-display font-bold text-2xl text-slate-900 mb-4">
            {tr.prices.discountCard.title}
          </h3>

          <p class="text-slate-800/80 text-sm leading-relaxed flex-1 mb-8">
            {tr.prices.discountCard.desc}
          </p>

          <a
            href="#prenota"
            class="flex items-center justify-center gap-2 bg-slate-900 hover:bg-slate-800 text-white font-semibold text-sm px-6 py-3 rounded-full transition-all duration-200 hover:scale-105 shadow-lg"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
            {tr.prices.discountCard.cta}
          </a>
        </div>
      </div>
    </div>

    <!-- Min stay note -->
    <p class="text-center text-slate-400 text-sm">{tr.prices.minStay}</p>

  </div>
</section>
