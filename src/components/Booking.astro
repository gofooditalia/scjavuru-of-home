---
import { t } from '../i18n/index';
import type { Lang } from '../i18n/index';
import ContactForm from './ContactForm.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = t(lang);

const BOOKING_URL = 'https://www.booking.com/hotel/it/scjavuru-of-home.it.html';

const room = {
  features: {
    it: ['Aria condizionata', 'Balcone', 'TV a schermo piatto', 'WiFi gratuito', 'Biancheria e asciugamani inclusi'],
    en: ['Air conditioning', 'Balcony', 'Flat-screen TV', 'Free WiFi', 'Linen and towels included'],
  },
};
---

<section id="prenota" class="py-20 lg:py-28 bg-[#111111] text-white">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-14">
      <h2 class="font-display text-4xl lg:text-5xl font-bold mb-4">
        {tr.booking.title}
      </h2>
      <p class="text-lg text-neutral-400 max-w-2xl mx-auto">
        {lang === 'it'
          ? 'Scrivici direttamente per ricevere il prezzo scontato — rispondiamo entro 24 ore.'
          : 'Contact us directly for a discounted rate — we reply within 24 hours.'}
      </p>
      <div class="mt-5 w-14 h-0.5 bg-amber-400 mx-auto"></div>
    </div>

    <!-- Form principale -->
    <ContactForm lang={lang} />

    <!-- Link secondario Booking.com -->
    <p class="text-center mt-6 text-sm text-neutral-500">
      {lang === 'it' ? 'Oppure prenota su' : 'Or book on'}
      <a href={BOOKING_URL} target="_blank" rel="noopener noreferrer"
        class="text-amber-400/80 hover:text-amber-400 underline underline-offset-4 transition-colors ml-1">
        Booking.com →
      </a>
    </p>
  </div>
</section>
