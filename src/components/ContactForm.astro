---
import { t } from '../i18n/index';
import type { Lang } from '../i18n/index';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const f = t(lang).form;

// ✏️ SETUP FORMSPREE (una tantum)
// 1. Vai su https://formspree.io e registrati
// 2. Crea un nuovo form
// 3. Sostituisci l'endpoint qui sotto
const FORMSPREE_ENDPOINT = 'https://formspree.io/f/xdajbqyb';

---

<div class="bg-[#141414] rounded-2xl border border-amber-400/25 shadow-xl shadow-amber-400/5 p-8 lg:p-10">

  <div data-fs-success class="text-center py-8">
    <div class="w-16 h-16 rounded-full bg-amber-400/10 border border-amber-400/30 flex items-center justify-center mx-auto mb-5">
      <svg class="w-8 h-8 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
      </svg>
    </div>
    <h3 class="font-display font-bold text-xl text-amber-400 mb-2">{f.successTitle}</h3>
    <p class="text-neutral-300 text-sm mt-1">{f.successMsg}</p>
    <button id="reset-form" class="mt-5 text-sm text-amber-400 underline underline-offset-4 hover:text-amber-300 transition-colors">
      {f.successReset}
    </button>
  </div>

  <div data-fs-error class="mb-5 text-sm text-rose-600 bg-rose-50 border border-rose-100 rounded-lg px-4 py-3"></div>

  <form id="contact-form">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-5 gap-y-4">

      <div class="flex flex-col gap-1">
        <label class="field-label" for="cf-name">{f.name} <span class="text-rose-400">*</span></label>
        <input id="cf-name" name="name" type="text" required placeholder={f.namePlaceholder} data-fs-field class="field-input" />
        <span data-fs-error="name" class="err-msg"></span>
      </div>

      <div class="flex flex-col gap-1">
        <label class="field-label" for="cf-email">{f.email} <span class="text-rose-400">*</span></label>
        <input id="cf-email" name="email" type="email" required placeholder={f.emailPlaceholder} data-fs-field class="field-input" />
        <span data-fs-error="email" class="err-msg"></span>
      </div>

      <div class="flex flex-col gap-1">
        <label class="field-label" for="cf-checkin">{f.checkin} <span class="text-rose-400">*</span></label>
        <input id="cf-checkin" name="checkin" type="text" required readonly autocomplete="off" data-fs-field class="field-input cursor-pointer" />
        <span data-fs-error="checkin" class="err-msg"></span>
      </div>

      <div class="flex flex-col gap-1">
        <label class="field-label" for="cf-checkout">{f.checkout} <span class="text-rose-400">*</span></label>
        <input id="cf-checkout" name="checkout" type="text" required readonly autocomplete="off" data-fs-field class="field-input cursor-pointer" />
        <span data-fs-error="checkout" class="err-msg"></span>
      </div>

      <div class="flex flex-col gap-1 sm:col-span-2">
        <label class="field-label" for="cf-message">{f.message}</label>
        <textarea id="cf-message" name="message" rows="3" placeholder={f.messagePlaceholder} data-fs-field class="field-input resize-none"></textarea>
        <span data-fs-error="message" class="err-msg"></span>
      </div>

    </div>

    <button type="submit" data-fs-submit-btn
      class="mt-6 w-full flex items-center justify-center gap-2 bg-amber-400 hover:bg-amber-500 text-slate-900 font-semibold text-base px-8 py-3.5 rounded-full transition-all duration-200 hover:scale-[1.02] shadow-md shadow-amber-400/30 disabled:opacity-60 disabled:cursor-not-allowed disabled:scale-100">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
      </svg>
      {f.submit}
    </button>
  </form>
</div>

<style>
  .field-label { font-size: 0.8125rem; font-weight: 500; color: #737373; }
  .field-input {
    width: 100%; border: 1px solid #2a2a2a; border-radius: 0.625rem;
    padding: 0.625rem 0.875rem; font-size: 0.9375rem; color: #f5f5f5;
    background: #1e1e1e; outline: none; transition: border-color 0.15s, box-shadow 0.15s;
    font-family: inherit;
  }
  .field-input:focus { border-color: #fbbf24; box-shadow: 0 0 0 3px rgba(251,191,36,0.12); background: #242424; }
  .field-input[aria-invalid="true"] { border-color: #f43f5e; box-shadow: 0 0 0 3px rgba(244,63,94,0.1); }
  .field-input::placeholder { color: #525252; }
  select.field-input { appearance: auto; color-scheme: dark; }
  .err-msg { font-size: 0.75rem; color: #f43f5e; min-height: 1rem; }
  :global(.flatpickr-day.selected),
  :global(.flatpickr-day.selected:hover),
  :global(.flatpickr-day.startRange),
  :global(.flatpickr-day.endRange) {
    background: #fbbf24; border-color: #fbbf24; color: #0a0a0a;
  }
  :global(.flatpickr-day:hover) { background: #2a2a2a; }
  :global(.flatpickr-calendar) { border: 1px solid #2a2a2a; z-index: 99999 !important; }
  :global([data-fs-success][data-fs-active]) {
    background: transparent !important;
    border: 1px solid #2a2a2a !important;
    border-radius: 0.75rem !important;
    padding: 2.5rem 1rem !important;
  }
  :global([data-fs-success][data-fs-active] ~ form),
  :global([data-fs-success][data-fs-active] ~ [data-fs-error]) {
    display: none !important;
  }
</style>

<script is:inline src="https://unpkg.com/@formspree/ajax@1" defer></script>
<script is:inline>
  window.formspree = window.formspree || function () {
    (formspree.q = formspree.q || []).push(arguments);
  };
  formspree('initForm', { formElement: '#contact-form', formId: 'xdajbqyb' });
</script>
<script>
  import flatpickr from 'flatpickr';
  import { Italian } from 'flatpickr/dist/l10n/it.js';
  import 'flatpickr/dist/themes/dark.css';

  function initPickers() {
    const lang = document.documentElement.lang;
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    const locale = lang === 'it' ? Italian : 'default';

    const checkoutPicker = flatpickr('#cf-checkout', {
      minDate: today,
      dateFormat: 'd/m/Y',
      locale,
    });

    flatpickr('#cf-checkin', {
      minDate: today,
      dateFormat: 'd/m/Y',
      locale,
      onChange(dates) {
        if (dates[0]) {
          const next = new Date(dates[0]);
          next.setDate(next.getDate() + 1);
          checkoutPicker.set('minDate', next);
          if (checkoutPicker.selectedDates[0] && checkoutPicker.selectedDates[0] <= dates[0]) {
            checkoutPicker.clear();
          }
        }
      },
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPickers);
  } else {
    initPickers();
  }

  document.getElementById('reset-form')?.addEventListener('click', () => {
    const successEl = document.querySelector('[data-fs-success]');
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    if (successEl) successEl.removeAttribute('data-fs-active');
    if (form) {
      form.reset();
      form.style.removeProperty('display');
    }
    initPickers();
  });
</script>
