---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import Gallery from '../../components/Gallery.astro';
import Booking from '../../components/Booking.astro';
import Map from '../../components/Map.astro';
import Prices from '../../components/Prices.astro';
import Footer from '../../components/Footer.astro';

const lang = 'en' as const;
---

<Layout
  title="Scjavuru of Home — Holiday Home in the heart of Palermo"
  description="Apartment in the heart of Palermo, in the historic city centre. Discover authentic Sicily."
  lang={lang}
>
  <Header lang={lang} />
  <main>
    <Hero lang={lang} />
    <Gallery lang={lang} />
    <Booking lang={lang} />
    <Map lang={lang} />
    <Prices lang={lang} />
  </main>
  <Footer lang={lang} />
</Layout>
